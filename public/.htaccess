RewriteEngine On

# If requested file or directory exists, serve it as is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect /api requests to api.php (PathInfo)
RewriteRule ^api/(.*)$ /api.php/$1 [L,QSA]

# Otherwise, redirect to index.html for SPA routing
RewriteRule ^ index.html [L]
